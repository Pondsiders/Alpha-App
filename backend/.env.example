# Alpha-App backend configuration. Copy to .env and fill in.

# Deployment mode. Defaults to prod if unset, which is the safe default
# for accidental launches but the wrong default for dev work — set this
# explicitly to dev or test depending on what you're doing.
MODE=dev

# The database the app talks to. Required in every mode.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Admin URL of a cluster (postgres database) where the test runner
# creates per-test nonce databases. Only the test fixture reads this;
# the app's runtime code never does. If MODE=prod and this is set, the
# app refuses to start — production does not get to know there is a
# test cluster.
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres

# Logfire write token for observability. Optional.
LOGFIRE_TOKEN=pylf_v1_us_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code plugin directory. Must contain .claude-plugin/plugin.json
# and prompts/soul.md. In production this is the alpha-identity plugin
# at /Pondside/Alpha-Home/Alpha; in dev it can be a test plugin.
JE_NE_SAIS_QUOI=/path/to/plugin

# Working directory for the Claude subprocess. Anchors the CLAUDE.md
# walk. Must be an absolute path to an existing directory. In production
# this is /Pondside; in dev it can be any scratch directory.
WORKING_DIRECTORY=/path/to/cwd

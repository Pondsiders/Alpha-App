# Alpha-App Docker build context filter
# Without this, Docker hashes 738MB+ including .venv and node_modules,
# which drowns out actual source changes and breaks cache invalidation.

# Python — the venv is 465MB of installed packages
backend/.venv/
**/__pycache__/
*.py[cod]
*.egg-info/

# Node — frontend builds from source in Stage 1; node_modules is 264MB
frontend/node_modules/
frontend/dist/

# Test artifacts (not needed in production image)
backend/tests/e2e/screenshots/

# Runtime data
data/

# Secrets
.env

# Docker meta (don't send ourselves)
.dockerignore
compose.yml

# IDE
.vscode/
.idea/

# Git
.git/
.gitignore

# OS
.DS_Store

# Large assets
Icon-iOS-Default-1024x1024@1x.png

# Alpha-App environment variables
# Copy to .env and fill in real values before running.
# Loaded by docker compose via `env_file: .env`.

TZ="America/Los_Angeles"

# ---------------------------------------------------------------------------
# Postgres (self-hosted, inside the compose stack)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:CHANGEME@localhost:5432/postgres"
POSTGRES_PASSWORD="CHANGEME"
POSTGRES_ROLE="primary"

# Streaming replication (when running as replica)
REPLICATION_PRIMARY_HOST="alpha.your-tailnet.ts.net"
REPLICATION_PRIMARY_PORT="5432"
REPLICATION_USER="replicator"
REPLICATION_PASSWORD="CHANGEME"

# ---------------------------------------------------------------------------
# Tailscale sidecar
# ---------------------------------------------------------------------------
TS_HOSTNAME="alpha"
TS_AUTHKEY="tskey-auth-XXXXXXXXXXXXXXXX"

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
# Either ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN is required.
# Generate the OAuth token with `claude setup-token` on a machine signed in
# to your subscription.
ANTHROPIC_API_KEY="sk-ant-api03-XXXXXXXXXXXXXXXX"
CLAUDE_CODE_OAUTH_TOKEN="sk-ant-oat01-XXXXXXXXXXXXXXXX"

# Behavior
# Effort level for supported models. Opus 4.7 uses adaptive reasoning by
# default; xhigh biases harder on complex tasks. Values: low | medium | high
# | xhigh | max | auto.
CLAUDE_CODE_EFFORT_LEVEL="xhigh"
# Disable auto-compaction. Keep manual /compact available as an escape hatch.
DISABLE_AUTO_COMPACT="1"
# Pin the CLI version; upgrade manually.
DISABLE_AUTOUPDATER="1"
# Suppress cost warnings (noise on a Max subscription).
DISABLE_COST_WARNINGS="1"
# Disable Claude Code's cron / /loop. We bring our own scheduler.
CLAUDE_CODE_DISABLE_CRON="1"
# Disable session recap — we keep our own continuity records.
CLAUDE_CODE_ENABLE_AWAY_SUMMARY="0"
# Disable auto-memory — we bring our own memory system.
CLAUDE_CODE_DISABLE_AUTO_MEMORY="1"
# Fail loud on stale model IDs; don't silently remap.
CLAUDE_CODE_DISABLE_LEGACY_MODEL_REMAP="1"

# Output limits (raise the 25K defaults so larger docs come through intact)
MAX_MCP_OUTPUT_TOKENS="100000"
CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS="100000"
TASK_MAX_OUTPUT_LENGTH="160000"

# Timeouts
BASH_DEFAULT_TIMEOUT_MS="300000"
BASH_MAX_TIMEOUT_MS="1800000"
API_TIMEOUT_MS="1200000"

# Claude Code → Logfire via OpenTelemetry
# Metrics: session/token/cost/active_time/tool_decision
# Events: user_prompt, api_request, api_error, tool_result, tool_decision (with prompt.id correlation)
# Traces intentionally NOT exported — the beta pipeline produces flat-root
# spans and broken outliers. Correlate via prompt.id and session.id instead.
CLAUDE_CODE_ENABLE_TELEMETRY="1"
OTEL_METRICS_EXPORTER="otlp"
OTEL_LOGS_EXPORTER="otlp"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_OTLP_ENDPOINT="https://logfire-us.pydantic.dev"
OTEL_EXPORTER_OTLP_HEADERS="Authorization=pylf_v1_us_XXXXXXXXXXXXXXXX"
# Unredact prompts and API bodies (private Logfire project).
OTEL_LOG_USER_PROMPTS="1"
OTEL_LOG_TOOL_DETAILS="1"
OTEL_LOG_RAW_API_BODIES="1"

# ---------------------------------------------------------------------------
# Alpha-App observability (Logfire)
# ---------------------------------------------------------------------------
LOGFIRE_TOKEN="pylf_v1_us_XXXXXXXXXXXXXXXX"
LOGFIRE_MIN_LEVEL="info"
ALPHA_TRACE_CLAUDE_STDIO="0"
ALPHA_TRACE_CLAUDE_STDIO_STREAMING="0"
ALPHA_TRACE_WS_BROADCAST="0"

# ---------------------------------------------------------------------------
# Object storage — Garage (inside the compose stack)
# ---------------------------------------------------------------------------
GARAGE_ACCESS_KEY_ID="GKXXXXXXXXXXXXXXXX"
GARAGE_SECRET_ACCESS_KEY="XXXXXXXXXXXXXXXX"

# ---------------------------------------------------------------------------
# Object storage — Backblaze B2 (WAL archive via aws cli)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID="000XXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="XXXXXXXXXXXXXXXX"

# ---------------------------------------------------------------------------
# External services
# ---------------------------------------------------------------------------
# Email
SPACEMAIL_PASSWORD="CHANGEME"
JEFFERY_EMAIL_PASSWORD="CHANGEME"

# Bluesky
BLUESKY_HANDLE="your-handle.bsky.social"
BLUESKY_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Home Assistant (long-lived access token)
HOME_ASSISTANT_API_TOKEN="eyJXXXXXXXXXXXXXXXX"

# Todoist
TODOIST_TOKEN="XXXXXXXXXXXXXXXX"

# Raindrop.io
RAINDROP_TOKEN="XXXXXXXXXXXXXXXX"

# NASA (APOD)
NASA_API_KEY="XXXXXXXXXXXXXXXX"

# GitHub (gh cli, repos, issues)
GITHUB_TOKEN="ghp_XXXXXXXXXXXXXXXX"

# Runpod (serverless image generation — dreams)
RUNPOD_API_KEY="rpa_XXXXXXXXXXXXXXXX"
RUNPOD_ENDPOINT_ID="XXXXXXXXXXXXXXXX"

# Identity override — point to a different JNSQ directory for testing.
# Default (when unset): /Pondside/Alpha-Home/Alpha
# JE_NE_SAIS_QUOI_OVERRIDE="/Pondside/Workshop/Projects/Alpha-App-frontend-v2/test_jnsq"

# Alpha-App environment variables
# Copy to .env and fill in real values before running.
# Docker reads this via `env_file: .env` in compose.yml.
# Bare metal: place .env at repo root; alpha_app/main.py loads it automatically.

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/dbname"

# ---------------------------------------------------------------------------
# TLS (optional — omit for local dev, required for HTTPS in production)
# ---------------------------------------------------------------------------
# SSL_CERTFILE="/path/to/cert.crt"
# SSL_KEYFILE="/path/to/cert.key"

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# LOGFIRE_TOKEN="your-logfire-token"

# ---------------------------------------------------------------------------
# Hostname override (optional — defaults to system hostname)
# ---------------------------------------------------------------------------
# HOST_HOSTNAME="my-machine"

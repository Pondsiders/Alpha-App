# Alpha-App environment variables
# Copy to .env and fill in real values before running.
# Docker reads this via `env_file: .env` in compose.yml.
# Bare metal: place .env at repo root; alpha_app/main.py loads it automatically.

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Anthropic / Claude
# Claude auth is via ~/.claude/.credentials.json — no API key env var needed.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Identity
# ---------------------------------------------------------------------------
# Path to the identity directory containing prompts/system/{soul.md,bill-of-rights.md}
JE_NE_SAIS_QUOI=/path/to/identity/directory

# ---------------------------------------------------------------------------
# Paths (defaults work for Docker; override for bare metal)
# ---------------------------------------------------------------------------
CONTEXT_ROOT=/Pondside
THUMBNAIL_DIR=/Pondside/Alpha-Home/images/thumbnails

# Working directory for session JSONL paths (default: current directory)
ALPHA_CWD=.

# ---------------------------------------------------------------------------
# Ollama (for recall/suggest)
# ---------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Hostname override (optional — defaults to system hostname)
# ---------------------------------------------------------------------------
# HOST_HOSTNAME=my-machine

# ---------------------------------------------------------------------------
# TLS (optional — omit for local dev, required for HTTPS in production)
# ---------------------------------------------------------------------------
# SSL_CERTFILE=/path/to/cert.crt
# SSL_KEYFILE=/path/to/cert.key

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# LOGFIRE_TOKEN=your-logfire-token
